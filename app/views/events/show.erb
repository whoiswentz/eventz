<section class="event-details">
    <div class="details">
        <h1><%= @event.name %></h1>
        <h2><%= price(@event) %></h2>
        <h3><%= format_date(@event) %> in <%= @event.location %></h3>
        <p><%= @event.description %></p>
    </div>
</section>
<section class="admin">
  <%= link_to "Edit", event_edit_path(@event), class: "button" %>
</section>